#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

case "$1" in
  models)
    shift
    node "$SCRIPT_DIR/dist/select-models.js" "$@"
    ;;
  blend)
    shift
    node "$SCRIPT_DIR/dist/blend-cli.js" "$@"
    ;;
  *)
    echo "Usage: smoothie <command>"
    echo ""
    echo "  models              Pick models interactively"
    echo "  models list         Show current models"
    echo "  models add <id>     Add a model by OpenRouter ID"
    echo "  models remove <id>  Remove a model"
    echo "  blend <prompt>      Run a blend from terminal"
    ;;
esac
