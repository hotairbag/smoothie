#!/bin/bash
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

case "$1" in
  models)
    shift
    node "$SCRIPT_DIR/dist/select-models.js" "$@"
    ;;
  blend)
    shift
    node "$SCRIPT_DIR/dist/blend-cli.js" "$@"
    ;;
  help|--help|-h|"")
    echo ""
    echo "  🧃 Smoothie — multi-model review for Claude Code"
    echo ""
    echo "  Usage: smoothie <command>"
    echo ""
    echo "  Models"
    echo "    models                  Pick models interactively"
    echo "    models list             Show current models"
    echo "    models add <id>         Add by OpenRouter model ID"
    echo "    models remove <id>      Remove a model"
    echo ""
    echo "  Blend"
    echo "    blend \"<prompt>\"        Run a blend from terminal"
    echo ""
    echo "  In Claude Code"
    echo "    /smoothie <problem>     Manual blend via slash command"
    echo "    auto-blend              Runs automatically on plans (if enabled)"
    echo ""
    ;;
  *)
    echo "  Unknown command: $1"
    echo "  Run 'smoothie help' for usage"
    ;;
esac
